generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id                Int                @id @default(autoincrement())
  firstName         String?            @map("first_name") @db.VarChar(255)
  lastName          String?            @map("last_name") @db.VarChar(255)
  email             String?            @db.VarChar(255)
  countryCode       String?            @map("country_code") @db.VarChar(255)
  phoneNumber       String?            @map("phone_number") @db.VarChar(20)
  password          String             @db.VarChar(255)
  gender            users_gender?
  resetCode         String?            @map("reset_code") @db.VarChar(20)
  resetCodeDate     DateTime?          @map("reset_code_date") @db.DateTime(0)
  isActive          Int                @default(1) @map("is_active") @db.TinyInt
  isActivated       Int                @default(0) @map("is_activated") @db.TinyInt
  type              Int
  languageId        Int                @default(1) @map("language_id")
  lastLogin         DateTime?          @map("last_login") @db.DateTime(0)
  mobileToken       String             @unique(map: "uniq_mobile_token") @map("mobile_token") @db.VarChar(255)
  webToken          String             @unique(map: "uniq_web_token") @map("web_token") @db.VarChar(255)
  mainImage         String?            @map("main_image") @db.VarChar(255)
  attachmentCounter Int?               @default(0) @map("attachment_counter")
  lockedBy          Int?               @map("locked_by")
  createdBy         Int?               @map("created_by")
  updatedBy         Int?               @map("updated_by")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  isProvider        Int?               @default(0) @map("is_provider") @db.TinyInt
  rStoreId          Int?               @map("r_store_id")
  appleIdentifier   String?            @map("apple_identifier") @db.VarChar(255)
  device_id         String?            @db.VarChar(255)
  device_type       users_device_type?
  showPrices        Int?               @map("show_prices")
  fault_code        fault_code[]
  sms_data          sms_data[]

  @@unique([countryCode, phoneNumber, type, email], map: "uniq_countr_phone")
  @@index([device_id], map: "idx_device_id")
  @@fulltext([firstName], map: "full_text_user_name")
  @@map("users")
}

model AgUserGroups {
  id               Int       @id @default(autoincrement())
  groupName        String    @map("group_name") @db.VarChar(50)
  groupDescription String    @map("group_description") @db.LongText
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  createdBy        Int?      @map("created_by")
  lockedBy         Int?      @map("locked_by")
  updatedBy        Int?      @map("updated_by")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("ag_user_groups")
}

model AgUsers {
  userId            Int       @id @default(autoincrement()) @map("user_id")
  userName          String    @map("user_name") @db.VarChar(100)
  firstName         String?   @map("first_name") @db.VarChar(200)
  lastName          String?   @map("last_name") @db.VarChar(200)
  userPassword      String    @map("user_password") @db.VarChar(250)
  userRole          Int       @map("user_role")
  emailAddress      String?   @map("email_address") @db.VarChar(255)
  address           String?   @db.Text
  phoneNumberOne    String?   @map("phone_number_one") @db.VarChar(20)
  token             String?   @db.VarChar(255)
  lastLogin         DateTime? @map("last_login") @db.DateTime(0)
  mainImage         String?   @map("main_image") @db.VarChar(255)
  lastUrl           String?   @map("last_url") @db.VarChar(255)
  link              String?   @unique(map: "unique_link") @db.VarChar(255)
  gender            Gender?
  countryCode       String    @map("country_code") @db.VarChar(100)
  description       String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  birthDate         DateTime? @map("birth_date") @db.Date
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  lockedBy          Int?      @map("locked_by")
  createdBy         Int?      @map("created_by")
  updatedBy         Int?      @map("updated_by")
  attachmentCounter Int?      @map("attachment_counter")
  resetCode         String?   @map("reset_code") @db.VarChar(100)
  resetCodeDate     DateTime? @map("reset_code_date") @db.DateTime(0)
  hasRelatedStore   Int?      @map("has_related_store") @db.TinyInt

  @@map("ag_users")
}

model Product {
  id                     Int                    @id @default(autoincrement())
  source                 String?                @default("manual") @db.VarChar(20)
  sourceProductId        String?                @map("source_product_id") @db.VarChar(100)
  productCode            String                 @map("product_code") @db.VarChar(200)
  productName            String?                @map("product_name") @db.VarChar(500)
  displayName            String?                @map("display_name") @db.VarChar(500)
  originalName           String?                @map("original_name") @db.VarChar(500)
  description            String?                @db.LongText
  displayDescription     String?                @map("display_description") @db.Text
  originalDescription    String?                @map("original_description") @db.Text
  model                  String?                @db.VarChar(100)
  brand                  Int?
  providerBrandId        Int?                   @map("provider_brand_id")
  opening_qty            Int                    @default(0)
  productQtyLeft         Float                  @default(0) @map("product_qty_left")
  productCost            Float                  @map("product_cost")
  productPrice           Float                  @map("product_price")
  originPrice            Decimal?               @map("origin_price") @db.Decimal(10, 2)
  showPrice              Decimal?               @map("show_price") @db.Decimal(10, 2)
  salePrice              Decimal?               @map("sale_price") @db.Decimal(10, 2)
  quantityBegin          Int?                   @default(1) @map("quantity_begin")
  product_price_2        Float
  product_price_3        Float
  hasOption              Int                    @default(0) @map("has_option") @db.TinyInt
  vat                    Float?
  product_weight         Float?
  booleanPercentDiscount Int                    @default(1) @map("boolean_percent_discount") @db.TinyInt
  salesDiscount          Float?                 @map("sales_discount")
  productCondition       Int?                   @map("product_condition")
  freeShipping           Int                    @default(1) @map("free_shipping") @db.TinyInt
  providerPrice          Float?                 @map("provider_price")
  provider_price_2       Float?
  provider_price_3       Float?
  flatRate               Int                    @default(0) @map("flat_rate") @db.TinyInt
  multiShipping          Int                    @default(0) @map("multi_shipping") @db.TinyInt
  shippingCost           Float?                 @map("shipping_cost")
  showOnWebsite          Int                    @map("show_on_website") @db.TinyInt
  isNew                  Boolean?               @default(false) @map("is_new")
  isComplete             Boolean?               @default(false) @map("is_complete")
  isSyncing              Boolean?               @default(false) @map("is_syncing")
  productSection         Int?                   @map("product_section")
  categoryId             Int?                   @map("category_id")
  product_view           Int                    @default(1)
  viewCount              Int?                   @default(0) @map("view_count")
  lastViewedAt           DateTime?              @map("last_viewed_at") @db.Timestamp(0)
  mainImage              String?                @map("main_image") @db.VarChar(255)
  imagesJson             String?                @map("images_json") @db.LongText
  videoUrl               String?                @map("video_url") @db.VarChar(500)
  shopLoginId            String?                @map("shop_login_id") @db.VarChar(255)
  shopUrl                String?                @map("shop_url") @db.VarChar(500)
  shopCompanyName        String?                @map("shop_company_name") @db.VarChar(500)
  shopIsSuperFactory     Boolean?               @default(false) @map("shop_is_super_factory")
  shopRepurchaseRate     String?                @map("shop_repurchase_rate") @db.VarChar(20)
  salesCount             Int?                   @default(0) @map("sales_count")
  buyerCount             Int?                   @default(0) @map("buyer_count")
  productUrl             String?                @map("product_url") @db.VarChar(500)
  attachmentCounter      Int?                   @default(0) @map("attachment_counter")
  lockedBy               Int?                   @map("locked_by")
  createdBy              Int                    @map("created_by")
  updatedBy              Int?                   @map("updated_by")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamp(0)
  discoveredAt           DateTime?              @map("discovered_at") @db.Timestamp(0)
  updatedAt              DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  lastSyncedAt           DateTime?              @map("last_synced_at") @db.Timestamp(0)
  nextSyncAt             DateTime?              @map("next_sync_at") @db.Timestamp(0)
  syncPriority           product_sync_priority? @default(medium) @map("sync_priority")
  syncFailures           Int?                   @default(0) @map("sync_failures")
  contentHash            String?                @map("content_hash") @db.VarChar(64)
  priceHash              String?                @map("price_hash") @db.VarChar(32)
  lastSyncError          String?                @map("last_sync_error") @db.Text
  rStoreId               Int?                   @map("r_store_id")
  rFlashId               Int?                   @map("r_flash_id")
  slug                   String                 @db.VarChar(255)
  oldDiscount            Float?                 @map("old_discount")
  currencyId             Int                    @map("currency_id")
  expressDelivery        Int                    @default(0) @map("express_delivery")
  syncId                 String?                @map("sync_id") @db.VarChar(100)
  productStatus          Int                    @map("product_status")
  outOfStock             Int                    @map("out_of_stock")
  karat                  Int?                   @default(0)
  website_price          Decimal?               @db.Decimal(10, 2)
  product_1688_info      Product1688Info[]
  product_variant        ProductVariant[]

  @@unique([source, sourceProductId], map: "uniq_product_source_source_product_id")
  @@index([categoryId], map: "idx_category")
  @@index([displayName(length: 100)], map: "idx_display_name")
  @@index([isComplete], map: "idx_is_complete")
  @@index([isNew], map: "idx_is_new")
  @@index([isSyncing], map: "idx_is_syncing")
  @@index([lastSyncedAt], map: "idx_last_synced")
  @@index([nextSyncAt], map: "idx_next_sync")
  @@index([salesCount], map: "idx_sales_count")
  @@index([shopLoginId], map: "idx_shop_login")
  @@index([source], map: "idx_source")
  @@index([sourceProductId], map: "idx_source_product")
  @@fulltext([productCode], map: "fulltext_prd_code")
  @@fulltext([productName], map: "fulltext_prd_name")
  @@map("product")
}

model Category {
  id                                                                   Int                           @id @default(autoincrement())
  source                                                               String?                       @default("manual") @db.VarChar(20)
  sourceCategoryId                                                     String?                       @map("source_category_id") @db.VarChar(100)
  showInNavbar                                                         Int                           @default(0) @map("show_in_navbar") @db.TinyInt
  slug                                                                 String                        @unique(map: "slug") @db.VarChar(100)
  fullPath                                                             String?                       @map("full_path") @db.Text
  categoryName                                                         String                        @map("category_name") @db.VarChar(250)
  categoryNameZh                                                       String?                       @map("category_name_zh") @db.VarChar(255)
  categoryNameEn                                                       String?                       @map("category_name_en") @db.VarChar(255)
  createdAt                                                            DateTime                      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                                                            DateTime                      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  parent                                                               Int?                          @map("parent")
  level                                                                Int?                          @default(0)
  hasChildren                                                          Boolean?                      @default(false) @map("has_children")
  orderNumber                                                          Int?                          @map("order_number")
  createdBy                                                            Int?                          @map("created_by")
  mainImage                                                            String?                       @map("main_image") @db.VarChar(255)
  attachmentCounter                                                    Int?                          @default(0) @map("attachment_counter")
  lockedBy                                                             Int?                          @map("locked_by")
  updatedBy                                                            Int?                          @map("updated_by")
  rStoreId                                                             Int?                          @default(1) @map("r_store_id")
  productCount                                                         Int                           @default(0) @map("product_count")
  totalProductsApi                                                     Int?                          @default(0) @map("total_products_api")
  productsInDb                                                         Int?                          @default(0) @map("products_in_db")
  highestProductId                                                     String?                       @map("highest_product_id") @db.VarChar(100)
  lowestProductId                                                      String?                       @map("lowest_product_id") @db.VarChar(100)
  fullySynced                                                          Boolean?                      @default(false) @map("fully_synced")
  lastSyncDirection                                                    category_last_sync_direction? @default(forward) @map("last_sync_direction")
  lastProductSync                                                      DateTime?                     @map("last_product_sync") @db.Timestamp(0)
  newProductsFound                                                     Int?                          @default(0) @map("new_products_found")
  lastCategorySync                                                     DateTime?                     @map("last_category_sync") @db.Timestamp(0)
  display                                                              Boolean                       @default(true)
  syncEnabled                                                          Boolean?                      @default(true) @map("sync_enabled")
  syncPriority                                                         category_sync_priority?       @default(medium) @map("sync_priority")
  cartBtn                                                              Int?                          @map("cart_btn") @db.TinyInt
  rGridId                                                              Int?                          @map("r_grid_id")
  type                                                                 Int
  syncId                                                               Int?                          @map("sync_id")
  childSynced                                                          Int?                          @default(0) @map("child_synced")
  lastChildCheck                                                       DateTime?                     @map("last_child_check") @db.DateTime(0)
  empty                                                                category_empty?
  category_access_stats                                                category_access_stats?
  excluded_categories_excluded_categories_category_idTocategory        excluded_categories?          @relation("excluded_categories_category_idTocategory")
  excluded_categories_excluded_categories_parent_excluded_idTocategory excluded_categories[]         @relation("excluded_categories_parent_excluded_idTocategory")

  @@index([fullySynced], map: "idx_fully_synced")
  @@index([lastProductSync], map: "idx_last_sync")
  @@index([level], map: "idx_level")
  @@index([lowestProductId], map: "idx_lowest_product_id")
  @@index([parent], map: "idx_parent")
  @@index([source], map: "idx_source")
  @@index([sourceCategoryId], map: "idx_source_category")
  @@index([syncPriority], map: "idx_sync_priority")
  @@fulltext([categoryName], map: "ft_category_name")
  @@map("category")
}

model Notification {
  id        Int      @id @default(autoincrement())
  rUserId   Int?     @map("r_user_id")
  isSeen    Int      @default(0) @map("is_seen")
  subject   String   @db.VarChar(200)
