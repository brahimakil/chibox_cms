}

model FlashSalesProducts {
  id         Int @id @default(autoincrement())
  rFlashId   Int @map("r_flash_id")
  rProductId Int @map("r_product_id")

  @@map("flash_sales_products")
}

model Orders {
  id                 Int       @id @default(autoincrement())
  rUserId            Int       @map("r_user_id")
  total              Float
  currency_id        Int?      @default(6)
  subtotal           Float?
  tax_amount         Float?    @default(0)
  discount_amount    Float?    @default(0)
  quantity           Int       @default(0)
  addressFirstName   String    @map("address_first_name") @db.VarChar(100)
  addressLastName    String    @map("address_last_name") @db.VarChar(100)
  addressCountryCode String    @map("address_country_code") @db.VarChar(50)
  addressPhoneNumber String    @map("address_phone_number") @db.VarChar(100)
  address            String    @db.VarChar(200)
  country            String    @db.VarChar(255)
  city               String    @db.VarChar(255)
  state              String?   @db.VarChar(50)
  routeName          String    @map("route_name") @db.VarChar(100)
  buildingName       String    @map("building_name") @db.VarChar(100)
  floorNumber        Int       @map("floor_number")
  status             Int       @default(9)
  shippingAmount     Float     @map("shipping_amount")
  clientNotes        String?   @map("client_notes") @db.Text
  notes              String?   @db.LongText
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  lockedBy           Int?      @map("locked_by")
  createdBy          Int?      @map("created_by")
  updatedBy          Int?      @map("updated_by")
  isPaid             Int       @default(0) @map("is_paid") @db.TinyInt
  paymentType        Int       @map("payment_type")
  paymentId          String?   @map("payment_id") @db.VarChar(255)
  couponCode         Int?      @map("coupon_code")
  rDeliveryCompanyId Int?      @map("r_delivery_company_id")
  branchId           Int?      @map("branch_id")
  pickUpDate         DateTime? @map("pick_up_date") @db.Date
  additionalDetails  String?   @map("additional_details") @db.Text

  @@index([createdAt], map: "idx_created_at")
  @@index([status], map: "idx_status")
  @@index([rUserId], map: "idx_user_id")
  @@map("orders")
}

