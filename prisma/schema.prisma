  @@map("ex_currency")
}

model Product1688Info {
  id                    BigInt   @id @default(autoincrement())
  productId             Int      @map("product_id")
  itemId                String   @unique(map: "item_id") @map("item_id") @db.VarChar(100)
  categoryId            String?  @map("category_id") @db.VarChar(100)
  rootCategoryId        String?  @map("root_category_id") @db.VarChar(100)
