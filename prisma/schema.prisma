  tableId   Int?     @map("table_id")
  rowId     Int?     @map("row_id")
  lockedBy  Int?     @map("locked_by")
  createdBy Int      @map("created_by")
  updatedBy Int?     @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("notifications")
}

model UsersNotifications {
  id             Int @id @default(autoincrement())
  rUserId        Int @map("r_user_id")
  notificationId Int @map("notification_id")
  isSeen         Int @map("is_seen")

  @@map("users_notifications")
}

model Brand {
  id                Int      @id @default(autoincrement())
  brandName         String?  @unique(map: "brand_name") @map("brand_name") @db.VarChar(200)
  slug              String   @db.VarChar(100)
  orderNumber       Int      @map("order_number")
  description       String?  @db.VarChar(200)
  productCount      Int      @default(0) @map("product_count")
  mainImage         String?  @map("main_image") @db.VarChar(255)
  attachmentCounter Int?     @default(0) @map("attachment_counter")
  lockedBy          Int?     @map("locked_by")
  createdBy         Int      @map("created_by")
  updatedBy         Int?     @map("updated_by")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  rStoreId          Int?     @map("r_store_id")
  rGridId           Int?     @map("r_grid_id")

  @@fulltext([brandName], map: "ft_brand_name")
  @@map("brand")
}

model ProductSections {
  id          Int      @id @default(autoincrement())
  sectionName String   @unique(map: "section_name") @map("section_name") @db.VarChar(100)
  slug        String   @db.VarChar(200)
  orderNumber Int      @map("order_number")
